# Core Supabase Connectivity
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend / Edge Function Connectivity
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Payment Gateways - M-Pesa STK Push
# Note: In production, these should ideally be stored in Supabase Vault via RPC
MPESA_ENVIRONMENT=sandbox # or production
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_WEBHOOK_SECRET=your_mpesa_webhook_secret

# Optional Master Gateway overrides (Legacy)
VITE_MASTER_ORDER_GATEWAY_API_KEY=your_admin_key_here
VITE_MASTER_ORDER_GATEWAY_SHOP_ID=your_shop_id_here
VITE_MASTER_ORDER_GATEWAY_URL=https://your-backend-domain.com/api/external
